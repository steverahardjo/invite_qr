# Database
DB_NAME=qr_invite
DB_USER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_PASSWORD=postgres
DB_SSLMODE=disable

# Server
PORT=8080
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_PASSWORD=admin123

# Invite Link Base URL (used in email/WhatsApp messages)
BASE_WEB_URL=http://localhost:8080/

# WhatsApp (optional — skip if not using WA)
WA_API_KEY=
WA_PHONE=

# Resend Email (optional — skip if not using email)
RESEND_API_KEY=
RESEND_EMAIL=
